<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Entitlements for the AutoRouter macOS app.

  The app embeds a local HTTP gateway on 127.0.0.1 and ships a
  WebView2-style webview that talks to it. We need:
    * com.apple.security.network.client so the gateway can forward
      requests to upstreams (OpenAI, Anthropic, Gemini).
    * com.apple.security.network.server so the gateway can listen
      on its loopback bind.
    * com.apple.security.files.user-selected.read-only so the
      "Reveal data dir" command can open the user-selected
      config folder in Finder.
  The app does not need the App Sandbox for the local-first use
  case; we leave sandboxing off to keep the in-process server
  architecture simple. The hardened runtime is enabled in
  tauri.conf.json so we get the App Store compatible entitlements
  enforced even without sandboxing.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>
    <key>com.apple.security.files.user-selected.read-only</key>
    <true/>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
</dict>
</plist>